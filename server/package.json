{
	"name": "book-catalog",
	"version": "0.1.0",
	"description": "日本国内で出版される書籍・雑誌の新刊情報を扱う Web API サーバー",
	"type": "module",
	"engines": {
		"node": ">=22.5.0"
	},
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc && node scripts/copy-sql.mjs",
		"start": "node dist/index.js",
		"typecheck": "tsc --noEmit",
		"test": "tsx --test test/**/*.test.ts",
		"seed": "tsx src/seed.ts",
		"openapi": "tsx scripts/gen-openapi.ts"
	},
	"dependencies": {
		"@hono/node-server": "^1.13.7",
		"@hono/swagger-ui": "^0.6.1",
		"@hono/zod-openapi": "^0.19.10",
		"hono": "^4.6.14",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@types/node": "^22.10.2",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2"
	}
}
